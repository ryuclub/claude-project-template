{
  "permissions": {
    "allow": [
      "Bash(git:*)"
    ],
    "additionalDirectories": [
      "./.claude/guidelines",
      "./design"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-load.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "git.*commit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/.remote-cache/.claude/hooks/pre-commit-review.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": false,
    "example-skills@anthropic-agent-skills": false,
    "claude-api@anthropic-agent-skills": false,
    "generic-jira-tools@claude-generic-skills": false,
    "generic-git-tools@claude-generic-skills": false
  },
  "skills": [
    ".claude/skills",
    ".claude/.remote-cache/skills"
  ]
}

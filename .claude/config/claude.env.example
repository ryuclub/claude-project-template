# 项目配置文件模板
# 用途：集中管理 API 凭证、云服务配置等敏感信息
# ⚠️  注意：复制此文件为 claude.env，填写实际凭证后，不要提交到 Git

# ============================================================================
# 必填变量
# ============================================================================

# Atlassian JIRA
ATLASSIAN_USERNAME="your-email@example.com"
ATLASSIAN_API_KEY="your-api-token-here"
ATLASSIAN_DOMAIN="mycompany.atlassian.net"
JIRA_PROJECT="ABC"

# Git
GIT_REPO_OWNER="your-org"
GIT_REPO_NAME="your-repo"
GIT_REPO_URL="https://github.com/${GIT_REPO_OWNER}/${GIT_REPO_NAME}.git"
GIT_BRANCH_BASE="main"

# ============================================================================
# AWS 配置（按需填写）
# ============================================================================

AWS_REGION="us-east-1"
AWS_ACCOUNT_ID="123456789012"
AWS_PROFILE="default"

# ============================================================================
# 数据库配置（按项目类型填写）
# ============================================================================

# PostgreSQL / MySQL
RDS_ENDPOINT="your-rds-endpoint.rds.amazonaws.com"
RDS_PORT="5432"
RDS_USERNAME="your-db-username"
RDS_PASSWORD="your-db-password"
RDS_DATABASE="your-database-name"

# ============================================================================
# 容器和部署（按项目类型填写）
# ============================================================================

ECR_REPO_NAME="your-services"
ECS_CLUSTER_NAME="your-cluster"

# ============================================================================
# 灰度部署配置（如需要，取消注释）
# ============================================================================

# CANARY_WEIGHT_PHASE1_OLD="95"
# CANARY_WEIGHT_PHASE1_NEW="5"
# CANARY_WEIGHT_PHASE2_OLD="80"
# CANARY_WEIGHT_PHASE2_NEW="20"

# ============================================================================
# 业务系统配置（按项目填写）
# ============================================================================

# STRIPE_API_KEY="sk_live_..."
# KAFKA_BROKERS="broker1:9092,broker2:9092"
# SESSION_STORE="redis"

# ============================================================================
# 日志监控（可选）
# ============================================================================

LOG_LEVEL="info"
# DD_API_KEY="your-datadog-api-key"
